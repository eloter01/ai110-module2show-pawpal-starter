classDiagram
    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str frequency
        +List~int~ weekdays
    }

    class Pet {
        +str name
        +str species
        +List~Task~ tasks
    }

    class Owner {
        +str name
        +List~Pet~ pets
        +int available_minutes
        +time day_start
        +all_tasks() List~(Pet, Task)~
    }

    class DailyPlan {
        +date day
        +List scheduled
        +List skipped
    }

    class Scheduler {
        +int available_minutes
        +time day_start
        +make_plan(pet_tasks, day) DailyPlan
        -_sort(pet_tasks) List~(Pet, Task)~
        -_fit(pet_tasks, day) DailyPlan
    }

    Owner "1" *-- "*" Pet : has
    Pet "1" *-- "*" Task : has
    Owner ..> Scheduler : configures
    Scheduler ..> DailyPlan : produces
